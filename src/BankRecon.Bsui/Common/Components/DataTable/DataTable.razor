@using System.Linq.Expressions
@typeparam TItem

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                @foreach (var column in Columns ?? new())
                {
                    <th style="@GetColumnStyle(column)">
                        @if (column.IsSortable && OnSortChange.HasDelegate)
                        {
                            <button class="btn btn-link btn-sm text-white p-0" @onclick="() => HandleSort(column)">
                                @column.Header
                                @if (IsSorted(column))
                                {
                                    <span>@GetSortIcon(column)</span>
                                }
                            </button>
                        }
                        else
                        {
                            @column.Header
                        }
                    </th>
                }
                @if (Actions != null)
                {
                    <th style="width: 100px;">Actions</th>
                }
            </tr>
        </thead>
        <tbody>
            @if (Items == null || Items.Count == 0)
            {
                <tr>
                    <td colspan="@((Columns?.Count ?? 0) + (Actions != null ? 1 : 0))" class="text-center text-muted py-4">
                        No data available.
                    </td>
                </tr>
            }
            else
            {
                @foreach (var item in Items)
                {
                    <tr>
                        @foreach (var column in Columns ?? new())
                        {
                            <td>
                                @if (column.CellTemplate != null)
                                {
                                    @column.CellTemplate(item)
                                }
                                else
                                {
                                    @GetCellValue(item, column)
                                }
                            </td>
                        }
                        @if (Actions != null)
                        {
                            <td>
                                @Actions(item)
                            </td>
                        }
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@code {
    /// <summary>
    /// The collection of items to display in the table.
    /// </summary>
    [Parameter]
    public List<TItem> Items { get; set; } = new();

    /// <summary>
    /// The list of column definitions for the table.
    /// </summary>
    [Parameter]
    public List<DataTableColumn<TItem>> Columns { get; set; } = new();

    /// <summary>
    /// Template for rendering action buttons in each row.
    /// </summary>
    [Parameter]
    public RenderFragment<TItem>? Actions { get; set; }

    /// <summary>
    /// Callback when sorting is requested.
    /// </summary>
    [Parameter]
    public EventCallback<(string PropertyName, bool IsDescending)> OnSortChange { get; set; }

    /// <summary>
    /// The current sort property name.
    /// </summary>
    [Parameter]
    public string? SortBy { get; set; }

    /// <summary>
    /// Whether the current sort is descending.
    /// </summary>
    [Parameter]
    public bool IsSortDescending { get; set; }

    private string GetColumnStyle(DataTableColumn<TItem> column)
    {
        return string.IsNullOrEmpty(column.Width) ? string.Empty : $"width: {column.Width};";
    }

    private object? GetCellValue(TItem item, DataTableColumn<TItem> column)
    {
        if (column.Property == null || item == null)
        {
            return null;
        }

        try
        {
            var compiled = column.Property.Compile();
            return compiled(item);
        }
        catch
        {
            return null;
        }
    }

    private bool IsSorted(DataTableColumn<TItem> column)
    {
        return !string.IsNullOrEmpty(SortBy) && SortBy == column.PropertyName;
    }

    private string GetSortIcon(DataTableColumn<TItem> column)
    {
        if (!IsSorted(column))
        {
            return string.Empty;
        }

        return IsSortDescending ? " ↓" : " ↑";
    }

    private async Task HandleSort(DataTableColumn<TItem> column)
    {
        if (!column.IsSortable)
        {
            return;
        }

        var isDescending = SortBy == column.PropertyName && !IsSortDescending;
        await OnSortChange.InvokeAsync((column.PropertyName, isDescending));
    }
}
