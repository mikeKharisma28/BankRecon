@page "/audit-logs/{LogIdParam}"
@using System.Text.Json
@using BankRecon.Bsui.Client.Features.Interfaces
@using BankRecon.Shared.Features.AuditLogs.Dtos
@inject IAuditLogService AuditLogService
@inject NavigationManager Navigation

<PageTitle>Audit Log Detail</PageTitle>

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-12">
            <button class="btn btn-link" @onclick="GoBack">
                ← Back to Logs
            </button>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="placeholder-glow">
            <div class="placeholder col-12 mb-3" style="height: 200px;"></div>
            <div class="placeholder col-12" style="height: 300px;"></div>
        </div>
    }
    else if (auditLog == null)
    {
        <div class="alert alert-danger" role="alert">
            <strong>Error:</strong> Audit log not found.
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-md-6">
                <div class="card mb-4">
                    <div class="card-header bg-light">
                        <h5 class="card-title mb-0">Audit Log Information</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Timestamp</label>
                            <div class="form-control" readonly>@auditLog.Timestamp.ToString("g")</div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Entity</label>
                            <div class="form-control" readonly>@auditLog.EntityName</div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Entity ID</label>
                            <code class="form-control" style="word-break: break-all;">@auditLog.EntityId</code>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Action</label>
                            <div>
                                <span class="badge @GetActionBadgeClass(auditLog.Action)">
                                    @auditLog.Action
                                </span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Performed By</label>
                            <div class="form-control" readonly>
                                @if (string.IsNullOrEmpty(auditLog.PerformedBy))
                                {
                                    <span class="text-muted">—</span>
                                }
                                else
                                {
                                    @auditLog.PerformedBy
                                }
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(auditLog.AffectedColumns))
                        {
                            <div class="mb-3">
                                <label class="form-label fw-bold">Affected Columns</label>
                                <div class="form-control" style="white-space: pre-wrap; word-break: break-word;" readonly>@auditLog.AffectedColumns</div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                @if (!string.IsNullOrEmpty(auditLog.OldValues))
                {
                    <div class="card mb-4">
                        <div class="card-header bg-light">
                            <h5 class="card-title mb-0">Old Values</h5>
                        </div>
                        <div class="card-body">
                            <textarea class="form-control" style="font-family: monospace; height: 250px;" readonly>@FormatJson(auditLog.OldValues)</textarea>
                        </div>
                    </div>
                }

                @if (!string.IsNullOrEmpty(auditLog.NewValues))
                {
                    <div class="card">
                        <div class="card-header bg-light">
                            <h5 class="card-title mb-0">New Values</h5>
                        </div>
                        <div class="card-body">
                            <textarea class="form-control" style="font-family: monospace; height: 250px;" readonly>@FormatJson(auditLog.NewValues)</textarea>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public string? LogIdParam { get; set; }

    private AuditLogDto? auditLog;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrEmpty(LogIdParam) || !Guid.TryParse(LogIdParam, out var logId))
        {
            Navigation.NavigateTo("/auditlogs");
            return;
        }

        await LoadAuditLogAsync(logId);
    }

    private async Task LoadAuditLogAsync(Guid logId)
    {
        isLoading = true;

        try
        {
            var response = await AuditLogService.GetAllAsync();

            if (response.IsSuccess && response.Result != null)
            {
                auditLog = response.Result.FirstOrDefault(x => x.Id == logId);
            }

            if (auditLog == null)
            {
                Navigation.NavigateTo("/auditlogs");
            }
        }
        catch
        {
            Navigation.NavigateTo("/auditlogs");
        }
        finally
        {
            isLoading = false;
        }
    }

    private string FormatJson(string? json)
    {
        if (string.IsNullOrEmpty(json))
        {
            return string.Empty;
        }

        try
        {
            using var doc = JsonDocument.Parse(json);
            return JsonSerializer.Serialize(doc.RootElement, new JsonSerializerOptions { WriteIndented = true });
        }
        catch
        {
            return json;
        }
    }

    private string GetActionBadgeClass(string action) =>
        action switch
        {
            "Create" => "bg-success",
            "Update" => "bg-warning text-dark",
            "Delete" => "bg-danger",
            _ => "bg-secondary"
        };

    private void GoBack()
    {
        Navigation.NavigateTo("/auditlogs");
    }
}
