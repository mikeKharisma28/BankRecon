@page "/auditlogs"
@using System.Text.Json
@using BankRecon.Bsui.Client.Features.Interfaces
@using BankRecon.Shared.Features.AuditLogs.Dtos
@using Microsoft.AspNetCore.Components.Web
@using MudBlazor
@inject IAuditLogService AuditLogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>Audit Logs</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6">
    <MudText Typo="Typo.h4" Class="mb-4">Audit Logs</MudText>

    <MudPaper Class="p-4 mb-4">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="RefreshAsync" Class="mb-3">
            <MudIcon Icon="@Icons.Material.Filled.Refresh" Class="mr-2"/>
            Refresh
        </MudButton>

        @if (isLoading)
        {
            <MudProgressLinear Indeterminate="true" Class="mb-3"/>
            <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="400px"/>
        }
        else if (auditLogs == null || auditLogs.Count == 0)
        {
            <MudAlert Severity="Severity.Info">No audit logs found.</MudAlert>
        }
        else
        {
            <MudDataGrid Items="@auditLogs.OrderByDescending(x => x.Timestamp)" Hover="true" Dense="true" Striped="true">
                <Columns>
                    <PropertyColumn Property="x => x.Timestamp" Title="Timestamp" Sortable="true">
                        <CellTemplate>
                            @context.Item.Timestamp.ToString("g")
                        </CellTemplate>
                    </PropertyColumn>
                    <PropertyColumn Property="x => x.EntityName" Title="Entity" Sortable="true"/>
                    <PropertyColumn Property="x => x.EntityId" Title="Entity ID" Sortable="true">
                        <CellTemplate>
                            <MudText Typo="Typo.caption" Class="text-truncate" Style="max-width: 150px;">
                                @context.Item.EntityId
                            </MudText>
                        </CellTemplate>
                    </PropertyColumn>
                    <TemplateColumn Title="Action" Sortable="false">
                        <CellTemplate>
                            <MudChip T="string" Size="Size.Small" Icon="@GetActionIcon(context.Item.Action)"
                                     Color="@GetActionColor(context.Item.Action)" Variant="Variant.Filled">
                                @context.Item.Action
                            </MudChip>
                        </CellTemplate>
                    </TemplateColumn>
                    <PropertyColumn Property="x => x.PerformedBy" Title="Performed By" Sortable="true">
                        <CellTemplate>
                            <MudText Typo="Typo.body2">
                                @(string.IsNullOrEmpty(context.Item.PerformedBy) ? "—" : context.Item.PerformedBy)
                            </MudText>
                        </CellTemplate>
                    </PropertyColumn>
                    <TemplateColumn Title="Actions" Sortable="false">
                        <CellTemplate>
                            <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Primary"
                                       OnClick="@(() => ViewDetails(context.Item.Id))">
                                View
                            </MudButton>
                        </CellTemplate>
                    </TemplateColumn>
                </Columns>
            </MudDataGrid>
        }
    </MudPaper>
</MudContainer>

@code {
    private List<AuditLogDto> auditLogs = new();
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
    }

    private async Task RefreshAsync()
    {
        isLoading = true;

        try
        {
            var response = await AuditLogService.GetAllAsync();

            if (response.IsSuccess && response.Result != null)
            {
                auditLogs = response.Result;
            }
            else
            {
                Snackbar.Add(response.Message ?? "Failed to load audit logs", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading audit logs: {ex.Message}", Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ViewDetails(Guid id)
    {
        Navigation.NavigateTo($"/auditlogs/{id}");
    }

    private string GetActionIcon(string action) =>
        action switch
        {
            "Create" => Icons.Material.Filled.Add,
            "Update" => Icons.Material.Filled.Edit,
            "Delete" => Icons.Material.Filled.Delete,
            _ => Icons.Material.Filled.Info
        };

    private Color GetActionColor(string action) =>
        action switch
        {
            "Create" => Color.Success,
            "Update" => Color.Warning,
            "Delete" => Color.Error,
            _ => Color.Default
        };
}
