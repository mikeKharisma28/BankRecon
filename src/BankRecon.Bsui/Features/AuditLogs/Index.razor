@page "/audit-logs"
@using System.Text.Json
@using BankRecon.Bsui.Client.Features.Interfaces
@using BankRecon.Bsui.Features.AuditLogs.Components
@using BankRecon.Shared.Features.AuditLogs.Dtos
@inject IAuditLogService AuditLogService
@inject NavigationManager Navigation

<PageTitle>Audit Logs</PageTitle>

<div class="row mb-4">
    <div class="col-md-6">
        <h2>Audit Logs</h2>
    </div>
    <div class="col-md-6 text-end">
        <button class="btn btn-primary" @onclick="RefreshAsync" disabled="@isLoading">
            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true" style="display: @(isLoading ? "inline-block" : "none");"></span>
            Refresh
        </button>
    </div>
</div>

@if (isLoading)
{
    <div class="placeholder-glow">
        <div class="placeholder col-12 mb-2" style="height: 40px;"></div>
        <div class="placeholder col-12 mb-2" style="height: 40px;"></div>
        <div class="placeholder col-12" style="height: 40px;"></div>
    </div>
}
else if (auditLogs == null || auditLogs.Count == 0)
{
    <div class="alert alert-info" role="alert">
        <strong>No audit logs found.</strong>
    </div>
}
else
{
    <AuditLogsTable AuditLogs="auditLogs" OnViewDetails="ViewDetails" />
}

@code {
    private List<AuditLogDto> auditLogs = new();
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
    }

    private async Task RefreshAsync()
    {
        isLoading = true;

        try
        {
            var response = await AuditLogService.GetAllAsync();

            if (response.IsSuccess && response.Result != null)
            {
                auditLogs = response.Result.OrderByDescending(x => x.Timestamp).ToList();
            }
            else
            {
                auditLogs = new();
            }
        }
        catch
        {
            auditLogs = new();
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ViewDetails(Guid id)
    {
        Navigation.NavigateTo($"/auditlogs/{id}");
    }
}
